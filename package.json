{
  "name": "ifinance",
  "version": "1.2.0",
  "description": "Intelligent Internal Income and Expense Management System",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run server\" \"wait-on http://localhost:3000 && electron .\"",
    "server": "node backend/server.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "finance",
    "expense",
    "income",
    "management",
    "electron"
  ],
  "author": "vzdev",
  "license": "MIT",
  "dependencies": {
    "@journeyapps/sqlcipher": "^5.3.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "node-telegram-bot-api": "^0.67.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "systeminformation": "^5.31.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ifinance.app",
    "productName": "iFinance",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "frontend/assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "frontend/assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "frontend/assets/icon.png"
    }
  }
}
